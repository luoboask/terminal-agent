# ===========================================
# LLM Provider 配置 (选择其一)
# ===========================================

# --- 选项 1: Qwen (通义千问) - 推荐 ---
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 Base URL (默认：https://dashscope.aliyuncs.com/compatible-mode/v1)
QWEN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# 可选：指定模型 (默认：qwen3.5-plus)
QWEN_MODEL=qwen3.5-plus

# --- 选项 2: Anthropic (原版) ---
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 选项 3: Ollama 本地模型 ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ===========================================
# 其他配置
# ===========================================

# MCP 服务器配置 (可选)
# JSON 格式，定义 MCP 服务器列表
MCP_SERVERS_CONFIG={"servers":{}}

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# 工作目录 (默认为当前目录)
# WORKDIR=/path/to/your/project
